@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Hint the build-time dependency prefixes so find_dependency succeeds
# without downstream consumers needing to add transitive deps to
# CMAKE_PREFIX_PATH. HINTS (searched before the default paths) avoids
# mutating the consumer's CMAKE_PREFIX_PATH, which a failing
# find_dependency's early return would leave un-restored.
set(_SHiPGS_extra_prefixes "@_geometry_prefix@")
list(FILTER _SHiPGS_extra_prefixes EXCLUDE REGEX "^$")

find_dependency(SHiPGeometry CONFIG REQUIRED HINTS ${_SHiPGS_extra_prefixes})
find_dependency(GeoModelCore CONFIG REQUIRED HINTS ${_SHiPGS_extra_prefixes})
find_dependency(GeoModelIO CONFIG REQUIRED HINTS ${_SHiPGS_extra_prefixes})
find_dependency(GeoModelG4 CONFIG REQUIRED HINTS ${_SHiPGS_extra_prefixes})
find_dependency(Geant4 REQUIRED HINTS ${_SHiPGS_extra_prefixes})
find_dependency(Threads REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/SHiPGeometryServiceTargets.cmake")

check_required_components(SHiPGeometryService)

unset(_SHiPGS_extra_prefixes)
