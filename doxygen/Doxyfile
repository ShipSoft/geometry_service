PROJECT_NAME           = "SHiP Geometry Service"
PROJECT_BRIEF          = "Framework-agnostic C++20 library wrapping the SHiP GeoModel geometry behind a stable interface."
OUTPUT_DIRECTORY       = doxygen
INPUT                  = include src apps
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HAVE_DOT               = YES
QUIET                  = YES
WARN_NO_PARAMDOC       = NO
USE_MDFILE_AS_MAINPAGE = README.md
INPUT                 += README.md
JAVADOC_AUTOBRIEF      = YES
